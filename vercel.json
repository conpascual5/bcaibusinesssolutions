{
  "framework": "vite",
  "buildCommand": "vite build && node scripts/build-api.mjs",
  "outputDirectory": "dist/public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "runtime": "nodejs@20.x"
    }
  }
}