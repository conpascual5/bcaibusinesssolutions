{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npx tsx scripts/init-db.ts && npm run build",
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.ts": {
      "memory": 512,
      "maxDuration": 60
    }
  }
}
